{
	"name": "swagger-php-annotation",
	"displayName": "Swagger-PHP Annotation",
	"description": "Swagger-PHP annotation completion and decorator",
	"license": "MIT",
	"publisher": "qvtec3",
	"version": "1.1.2",
	"engines": {
		"vscode": "^1.56.0"
	},
	"categories": [
		"Programming Languages",
		"Snippets",
		"Other"
	],
	"keywords": [
		"openapi",
		"swagger",
		"php",
		"api"
	],
	"activationEvents": [
		"onLanguage:php"
	],
	"icon": "assets/icon.png",
	"main": "./out/extension.js",
	"contributes": {
		"configuration": {
			"type": "object",
			"title": "Swagger-PHP Annotation",
			"properties": {
				"completions.type": {
					"type": "string",
					"default": "OA",
					"description": "Swagger Version 2.x:SWG, 3.x:OA"
				},
				"decorator.regexes": {
					"type": "object",
					"description": "Object mapping regexes to an array of decorations to apply to the capturing groups",
					"default": {
						"(?:\\* )(@OA\\\\\\w+)": {
							"decorationType": {
								"light": {
									"color": "#cb85cc"
								},
								"dark": {
									"color": "#cb85cc"
								}
							}
						},
						"(?:\\* \\s+)(@OA\\\\\\w+)": {
							"decorationType": {
								"light": {
									"color": "#6c83bd"
								},
								"dark": {
									"color": "#6c83bd"
								}
							}
						},
						"(?:\\*\\s+)(\\w+)(?:=)": {
							"decorationType": {
								"light": {
									"color": "#998554"
								},
								"dark": {
									"color": "#998554"
								}
							}
						}
					}
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src --ext ts",
		"test": "node ./out/test/runTest.js",
		"package": "vsce package",
		"reinstall": "npm run compile && npm run package && code --install-extension swagger-php-annotation-$(node -p \"require('./package.json').version\").vsix"
	},
	"devDependencies": {
		"@types/glob": "^7.1.3",
		"@types/mocha": "^10.0.10",
		"@types/node": "^12.11.7",
		"@types/vscode": "^1.56.0",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"@vscode/test-electron": "^2.4.0",
		"@vscode/vsce": "^3.9.2",
		"eslint": "^8.57.1",
		"glob": "^7.1.6",
		"mocha": "^11.7.6",
		"typescript": "^4.1.3"
	},
	"overrides": {
		"diff": "^9.0.0",
		"serialize-javascript": "^7.0.0",
		"glob": {
			"minimatch": "^3.1.4"
		}
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/qvtec/swagger-php-annotation.git"
	}
}
